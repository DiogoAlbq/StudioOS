{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "StudioOS",
  "version": "3.0.1",
  "identifier": "com.studioos.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "StudioOS",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "rpm", "dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5QUFERUE2OUE4N0RDNzYKUldSMjNJZWFwdDZxdVQvZnhjSFRzZ2FJYWJSRkpwSXZEMG5XSjdSN0F6TEcyb2ViZ1k1T2ZGODEK",
      "endpoints": [
        "https://github.com/DiogoAlbq/StudioOS/releases/latest/download/latest.json"
      ]
    }
  }
}
